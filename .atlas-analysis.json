  "publicApiSurface": [
    "clickBuscar() - Search transfer market",
    "clickEncontrado() - Click on found items",
    "comprar() - Purchase items",
    "ponerMercado() - List items for sale",
    "definirPrecio() - Set sale prices",
    "limpiarvendidos() - Clear sold items",
    "enviarWhatsapp() - Send WhatsApp messages",
    "enviarScreenshot() - Send screenshots via WhatsApp",
    "buscarRango() - Find optimal price range",
    "revisarPrecio() - Review and adjust pricing",
    "recorrerBid() - Iterate through bidding items",
    "selecciones() - Apply search filters",
    "reLogin() - Re-authenticate to FIFA web app",
    "Firebase command: DETENER - Stop bot",
    "Firebase command: INICIAR - Start bot",
    "Firebase command: SCREENSHOT - Capture screen"
  ]
